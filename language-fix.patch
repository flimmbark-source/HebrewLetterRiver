+  for (let i = 0; i < lines.length; i += 1) {
+    const line = lines[i].trim();
+    if (!line || LINE_IGNORE_PATTERNS.some((p) => p.test(line))) continue;
+    const textNodes = [...line.matchAll(/>([^<{][^<>{]{2,})</g)].map((m) => m[1].trim());
+    const attrs = [...line.matchAll(/\b(?:label|title|placeholder|alt)="([^"]+)"/g)].map((m) => `${m[0].split('=')[0]}="${m[1]}"`);
