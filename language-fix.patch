diff --git a/src/views/HomeProfileLocalization.test.js b/src/views/HomeProfileLocalization.test.js
new file mode 100644
index 0000000000000000000000000000000000000000..31f6ec43fcb5f55e18b1cac3c5112a700a9b364c
--- /dev/null
+++ b/src/views/HomeProfileLocalization.test.js
@@ -0,0 +1,60 @@
+import { describe, it, expect } from 'vitest';
+import fs from 'node:fs';
+import path from 'node:path';
+
+const i18nDir = path.resolve('src/i18n');
+const homeViewPath = path.resolve('src/views/HomeView.jsx');
+const localeFiles = fs.readdirSync(i18nDir).filter((file) => file.endsWith('.json'));
+
+const requiredKeys = [
+  'dailyReview.title',
+  'dailyReview.allCaughtUp',
+  'dailyReview.checkBackTomorrow',
+  'home.sections.languageLearning',
+  'home.languagePicker.appLanguage',
+  'home.languagePicker.imLearning',
+  'home.languagePicker.active',
+  'home.sections.profileOverview',
+  'home.progress.recentMastery',
+  'home.progress.recentMasteryEmpty',
+  'home.progress.gameActivity',
+  'home.progress.gameActivityEmpty',
+  'streak.startJourney',
+  'app.nav.achievements',
+];
+
+function getPath(obj, dottedKey) {
+  return dottedKey.split('.').reduce((acc, part) => (acc && typeof acc === 'object' ? acc[part] : undefined), obj);
+}
+
+describe('Home/Profile localization coverage', () => {
+  it('does not leave known Home/Profile English strings hardcoded in HomeView JSX', () => {
+    const src = fs.readFileSync(homeViewPath, 'utf8');
+    const forbiddenTextNodes = [
+      'Language Learning',
+      'App Language',
+      "I\'m Learning",
+      'Active',
+      'Profile Overview',
+      'Recent Mastery',
+      'Catch a few letters to unlock your mastery row.',
+      'Game Activity',
+      'Start a game and your latest activity will appear here.',
+    ];
+
+    for (const phrase of forbiddenTextNodes) {
+      expect(src).not.toContain(`>${phrase}<`);
+    }
+  });
+
+  it('defines required Home/Profile keys for every app-language dictionary', () => {
+    for (const file of localeFiles) {
+      const dict = JSON.parse(fs.readFileSync(path.join(i18nDir, file), 'utf8'));
+      for (const key of requiredKeys) {
+        const value = getPath(dict, key);
+        expect(value, `${file} missing ${key}`).toBeTypeOf('string');
+        expect(value.trim().length, `${file} empty ${key}`).toBeGreaterThan(0);
+      }
+    }
+  });
+});
